#!/bin/bash
# ============================================================
# Git pre-commit hook — 技术强约束
#
# 规则：
#   1. OpenAPI 产物与代码不一致 → 拒绝提交
#   2. 单元测试失败 → 拒绝提交
#   3. Python 源码有语法错误 → 拒绝提交
#
# 绕过（紧急情况）：
#   git commit --no-verify
#
# 安装：
#   git config core.hooksPath .githooks
#   或 make setup
# ============================================================

set -e
RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  pre-commit: 契约一致性检查"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# ── 1. Python 编译检查（语法错误直接拦） ──
echo ""
echo "[1/3] Python 编译检查..."
python -m compileall -q apps workers packages migrations 2>&1
echo -e "${GREEN}✓${NC} 编译通过"

# ── 2. OpenAPI 产物一致性 ──
echo ""
echo "[2/3] OpenAPI 产物一致性..."
if python scripts/generate_openapi.py --check 2>&1; then
    echo -e "${GREEN}✓${NC} OpenAPI 与代码一致"
else
    echo ""
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${RED}  拒绝提交：OpenAPI 产物已过期${NC}"
    echo -e "${RED}  请运行: python scripts/generate_openapi.py${NC}"
    echo -e "${RED}  然后重新 git add contracts/generated/openapi/${NC}"
    echo -e "${RED}  紧急绕过: git commit --no-verify${NC}"
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    exit 1
fi

# ── 3. 单元测试 ──
echo ""
echo "[3/3] 单元测试 + OpenAPI 测试..."
if python -m pytest tests/unit tests/test_openapi.py -q 2>&1; then
    echo -e "${GREEN}✓${NC} 测试通过"
else
    echo ""
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${RED}  拒绝提交：测试失败${NC}"
    echo -e "${RED}  请修复失败的测试后重新提交${NC}"
    echo -e "${RED}  紧急绕过: git commit --no-verify${NC}"
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    exit 1
fi

echo ""
echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${GREEN}  全部通过，允许提交${NC}"
echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""
