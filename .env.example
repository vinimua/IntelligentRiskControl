# ── 环境 ──
ENV=development

# ── FastAPI ──
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# ── PostgreSQL ──
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=riskitem
POSTGRES_USER=riskitem
POSTGRES_PASSWORD=riskitem_dev
DATABASE_URL=postgresql+asyncpg://riskitem:riskitem_dev@localhost:5432/riskitem
DATABASE_URL_SYNC=postgresql+psycopg://riskitem:riskitem_dev@localhost:5432/riskitem

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── MinIO ──
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=riskitem
MINIO_SECURE=false

# ── MLflow ──
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_S3_ENDPOINT_URL=http://localhost:9000
MLFLOW_ARTIFACT_ROOT=s3://riskitem/mlflow/

# ── Neo4j ──
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=riskitem_dev

# ── Qdrant ──
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_ALIAS=risk_knowledge_current

# ── 日志 ──
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── 测试 ──
TEST_DATABASE_URL=postgresql+asyncpg://riskitem:riskitem_dev@localhost:5432/riskitem_test
SKIP_INTEGRATION=false
RUN_INFRA_TESTS=false
